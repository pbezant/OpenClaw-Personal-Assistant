# ─────────────────────────────────────────────────────────────────────────────
# OpenClaw Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
# Your Discord bot token (from Discord Developer Portal → Bot → Token)
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# ── LLM Backend (set ONE of the following) ────────────────────────────────────
# Option A: Anthropic Claude (recommended — same model as VS Code Copilot)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Option B: OpenAI GPT-4o (alternative)
# OPENAI_API_KEY=your-openai-api-key-here

# ── Optional ──────────────────────────────────────────────────────────────────
# Override the LLM model (defaults: claude-3-5-sonnet-20241022 / gpt-4o)
# LLM_MODEL=claude-3-5-sonnet-20241022

# Restrict bot to specific Discord servers (comma-separated guild IDs)
# Leave empty to allow any server the bot is added to.
# ALLOWED_GUILD_IDS=1234567890,9876543210
